{
  "manifest_version": 2,
  "version": "1.1.0",
  "name": "Telegram_Adapter_Plus",
  "description": "Telegram Bot API adapter plugin for MaiBot (fork by Raya Friandion)",
  "author": {
    "name": "薄暝, Raya Friandion",
    "url": "https://github.com/rayafriandion/MaiBot-telegram-adapter-plus"
  },
  "license": "AGPL-v3.0-or-later",
  "urls": {
    "repository": "https://github.com/rayafriandion/MaiBot-telegram-adapter-plus",
    "homepage": "https://github.com/rayafriandion/MaiBot-telegram-adapter-plus",
    "issues": "https://github.com/rayafriandion/MaiBot-telegram-adapter-plus/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "emoji.get_random",
    "send.emoji",
    "send.text",
    "send.image",
    "send.command",
    "config.get_plugin",
    "tool.get_definitions"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN",
      "en-US"
    ]
  },
  "id": "imai.telegram-adapter-plus"
}
